PORT=3000
NODE_ENV=development

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Scraper
REQUEST_TIMEOUT=15000
REQUEST_RETRIES=3
REQUEST_QUEUE_CONCURRENCY=5
BASE_URL=https://anoboy.be

# CORS
ALLOWED_ORIGINS=*
